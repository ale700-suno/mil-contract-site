# Скопируйте в .env.local и заполните значения

TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
# ID чата, куда бот будет слать заявки (личка, группа или канал)
TELEGRAM_CHAT_ID=your_chat_id

# Как узнать TELEGRAM_CHAT_ID:
# 1. Напишите боту любое сообщение (например /start)
# 2. Откройте в браузере: https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Найдите "chat":{"id":123456789} — это и есть TELEGRAM_CHAT_ID
